M190 S70    ; Set & wait for bed temp. !Don't modify/delete, only move!
M109 S235 ; Set & wait for hotend temp. !Don't modify/delete, only move!
START_PRINT T_BED=70 T_EXTRUDER=235
;
; Make sure this macro name matches your own!
; (For example, some may use START_PRINT instead.)
G21 ; Millimeter units
G90 ; Absolute XYZ
M83 ; Relative E
G92 E0 ; Reset extruder distance
;
;  Begin printing
;
M106 S0 ; Set fan speed
SET_VELOCITY_LIMIT ACCEL=4000 ; Set printing acceleration
G1 E-1 F3000 ; Retract
G0 Z5 F12000 ; Z raise
G0 X133.4244 Y136.5068 F12000 ; Move to start position
G0 Z0.2 F12000 ; Move to start layer height
G1 E1 F1800 ; Un-retract
SET_PRESSURE_ADVANCE ADVANCE=0.04 ; Set pressure advance to start value
