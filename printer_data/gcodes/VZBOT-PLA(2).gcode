M190 S60 ; Set & wait for bed temp
M109 S200 ; Set & wait for hotend temp
START_PRINT T_BED=60 T_EXTRUDER=200
G21 ; Millimeter units
G90 ; Absolute XYZ
M83 ; Relative E
G92 E0 ; Reset extruder distance
;
;  Begin printing
